datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// =============================================
// ADMIN DOMAIN
// =============================================

model Admin {
  id           String             @id @default(uuid())
  name         String
  email        String             @unique
  role         AdminRole
  status       AdminStatus        @default(active)
  twoFaEnabled Boolean            @default(false)
  twoFaSecret  String?
  lastLogin    DateTime?
  passwordHash String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  activityLogs AdminActivityLog[]
  sessions     AdminSession[]
}

enum AdminRole {
  superadmin
  admin
  viewer
  engineer
  financial_manager
  support_agent
}

enum AdminStatus {
  active
  inactive
}

model AdminActivityLog {
  id        String   @id @default(uuid())
  adminId   String
  admin     Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  category  String
  action    String
  details   String?
  ip        String?
  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([createdAt])
}

model AdminSession {
  id         String   @id @default(uuid())
  adminId    String
  admin      Admin    @relation(fields: [adminId], references: [id], onDelete: Cascade)
  ip         String
  userAgent  String?
  city       String?
  country    String?
  loginAt    DateTime @default(now())
  lastSeenAt DateTime @default(now())
  active     Boolean  @default(true)

  @@index([adminId])
}

model AdminRoleDefinition {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  permissions Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("admin_role_definitions")
}

// =============================================
// CRM DOMAIN
// =============================================

enum LeadStatus {
  new_lead      @map("new")
  contacted
  qualified
  proposal_sent
  won
  lost
}

enum LeadSource {
  website
  referral
  cold_call
  social_media
  other
}

model Lead {
  id                String     @id @default(uuid())
  name              String
  email             String?
  phone             String?
  address           String?
  city              String?
  source            LeadSource @default(other)
  status            LeadStatus @default(new_lead)
  assignedTo        String?
  assignedToId      String?
  interestedIn      String?
  notes             String?
  followUpDate      DateTime?
  convertedAt       DateTime?
  convertedClientId String?
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  @@index([status])
}

model Partner {
  id           String   @id @default(uuid())
  name         String
  status       String   @default("active")
  primaryEmail String?
  phone        String?
  address      String?
  city         String?
  country      String?
  timezone     String?
  currency     String?
  logoUrl      String?
  clientCount  Int      @default(0)
  adminCount   Int      @default(0)
  comision     Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// =============================================
// MESSAGING DOMAIN
// =============================================

model Message {
  id        String    @id @default(uuid())
  subject   String
  body      String
  fromId    String
  fromName  String
  toId      String?
  toName    String?
  clientId  String?
  channel   String    @default("internal")
  status    String    @default("unread")
  threadId  String?
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([clientId])
  @@index([status])
}

model ClientComment {
  id         String   @id @default(uuid())
  clientId   String
  authorName String
  content    String
  createdAt  DateTime @default(now())

  @@index([clientId])
}

model Notification {
  id        String    @id @default(uuid())
  type      String
  title     String
  message   String
  severity  String    @default("info")
  read      Boolean   @default(false)
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())
}

// =============================================
// FINANCE DOMAIN
// =============================================

model CreditNote {
  id               String    @id @default(uuid())
  number           String    @unique
  clientId         String
  clientName       String
  amount           Float
  taxAmount        Float     @default(0)
  totalAmount      Float
  reason           String
  relatedInvoiceId String?
  status           String    @default("draft")
  notes            String?
  issuedAt         DateTime  @default(now())
  appliedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([clientId])
}

model ProformaInvoice {
  id                   String    @id @default(uuid())
  number               String    @unique
  clientId             String
  clientName           String
  items                Json
  subtotal             Float
  taxAmount            Float     @default(0)
  total                Float
  status               String    @default("draft")
  notes                String?
  issuedAt             DateTime  @default(now())
  validUntil           DateTime?
  convertedToInvoiceId String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([clientId])
}

model FinanceHistoryEvent {
  id          String   @id @default(uuid())
  type        String
  description String
  clientId    String
  clientName  String
  amount      Float?
  referenceId String?
  adminId     String
  adminName   String
  occurredAt  DateTime @default(now())

  @@index([clientId])
  @@index([occurredAt])
}

// =============================================
// SETTINGS DOMAIN
// =============================================

model SystemSettings {
  id            String   @id @default("singleton")
  companyName   String   @default("IPNEXT")
  timezone      String   @default("America/Argentina/Buenos_Aires")
  currency      String   @default("ARS")
  language      String   @default("es")
  dateFormat    String   @default("DD/MM/YYYY")
  invoicePrefix String   @default("FAC")
  supportEmail  String?
  website       String?
  updatedAt     DateTime @updatedAt
}

model EmailSettings {
  id           String   @id @default("singleton")
  smtpHost     String?
  smtpPort     Int      @default(587)
  smtpUser     String?
  smtpPassword String?
  fromName     String?
  fromEmail    String?
  useTls       Boolean  @default(true)
  updatedAt    DateTime @updatedAt
}

model MessageTemplate {
  id        String   @id @default(uuid())
  name      String
  type      String
  subject   String?
  body      String
  variables Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ApiToken {
  id          String    @id @default(uuid())
  name        String
  token       String    @unique
  permissions Json
  lastUsed    DateTime?
  createdAt   DateTime  @default(now())
}

model PaymentMethod {
  id      String  @id @default(uuid())
  name    String
  type    String
  enabled Boolean @default(true)
  config  Json?
}

model Webhook {
  id            String    @id @default(uuid())
  name          String
  url           String
  events        Json
  secret        String?
  status        String    @default("active")
  lastTriggered DateTime?
  lastStatus    String?
  createdAt     DateTime  @default(now())
}

model BackupRecord {
  id          String   @id @default(uuid())
  filename    String
  sizeBytes   Int
  type        String   @default("manual")
  status      String   @default("completed")
  downloadUrl String?
  createdAt   DateTime @default(now())
}

model ClientPortalSettings {
  id                       String   @id @default("singleton")
  enabled                  Boolean  @default(false)
  portalUrl                String?
  allowSelfRegistration    Boolean  @default(false)
  requireEmailVerification Boolean  @default(true)
  allowPaymentOnline       Boolean  @default(false)
  allowTicketCreation      Boolean  @default(true)
  allowServiceManagement   Boolean  @default(false)
  welcomeMessage           String?
  logoUrl                  String?
  primaryColor             String   @default("#3B82F6")
  customCss                String?
  updatedAt                DateTime @updatedAt
}

// =============================================
// SCHEDULING DOMAIN
// =============================================

model ScheduledTask {
  id             String    @id @default(uuid())
  title          String
  description    String?
  assignedTo     String?
  assignedToId   String?
  clientId       String?
  clientName     String?
  status         String    @default("pending")
  priority       String    @default("normal")
  scheduledDate  String
  scheduledTime  String
  estimatedHours Float     @default(1)
  address        String?
  lat            Float?
  lng            Float?
  category       String    @default("installation")
  notes          String?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([status])
  @@index([scheduledDate])
}

// =============================================
// VOIP DOMAIN
// =============================================

model VoipCategory {
  id             String @id @default(uuid())
  name           String
  prefix         String
  pricePerMinute Float
  freeMinutes    Int    @default(0)
  status         String @default("active")
}

model VoipCdr {
  id           String   @id @default(uuid())
  clientId     String
  clientName   String
  callerNumber String
  calledNumber String
  duration     Int
  categoryId   String?
  categoryName String?
  cost         Float    @default(0)
  status       String   @default("answered")
  startedAt    DateTime @default(now())

  @@index([clientId])
  @@index([startedAt])
}

model VoipPlan {
  id              String @id @default(uuid())
  name            String
  monthlyPrice    Float
  includedMinutes Int    @default(0)
  categories      Json
  status          String @default("active")
}

// =============================================
// NETWORK DOMAIN
// =============================================

model ServicePlan {
  id              String  @id @default(uuid())
  name            String
  type            String
  planSubtype     String?
  downloadSpeed   Int?
  uploadSpeed     Int?
  price           Float
  billingCycle    String  @default("monthly")
  status          String  @default("active")
  description     String?
  subscriberCount Int     @default(0)
}

model NetworkDevice {
  id         String    @id @default(uuid())
  name       String
  type       String
  ipAddress  String?
  macAddress String?
  location   String?
  status     String    @default("online")
  model      String?
  lastSeen   DateTime?
  createdAt  DateTime  @default(now())
}

model InventoryItem {
  id        String  @id @default(uuid())
  name      String
  category  String
  sku       String?
  quantity  Int     @default(0)
  minStock  Int     @default(0)
  unitPrice Float   @default(0)
  supplier  String?
  location  String?
  status    String  @default("in_stock")
}

model InventoryProduct {
  id          String          @id @default(uuid())
  name        String
  category    String
  sku         String?
  description String?
  unitPrice   Float
  supplier    String?
  totalStock  Int             @default(0)
  minStock    Int             @default(0)
  status      String          @default("in_stock")
  units       InventoryUnit[]
}

model InventoryUnit {
  id                 String           @id @default(uuid())
  productId          String
  product            InventoryProduct @relation(fields: [productId], references: [id])
  serialNumber       String?
  barcode            String?
  status             String           @default("available")
  location           String?
  purchaseDate       DateTime?
  purchasePrice      Float?
  assignedToClientId String?
  assignedAt         DateTime?
  notes              String?

  @@index([productId])
}

model IpNetwork {
  id          String   @id @default(uuid())
  name        String
  network     String
  status      String   @default("active")
  description String?
  gateway     String?
  dns1        String?
  dns2        String?
  pools       IpPool[]
  createdAt   DateTime @default(now())
}

model IpPool {
  id          String         @id @default(uuid())
  networkId   String
  network     IpNetwork      @relation(fields: [networkId], references: [id])
  name        String
  rangeStart  String
  rangeEnd    String
  status      String         @default("active")
  assignments IpAssignment[]

  @@index([networkId])
}

model IpAssignment {
  id         String    @id @default(uuid())
  poolId     String
  pool       IpPool    @relation(fields: [poolId], references: [id])
  ipAddress  String
  clientId   String?
  clientName String?
  assignedAt DateTime  @default(now())
  releasedAt DateTime?

  @@index([poolId])
  @@index([clientId])
}

model NetworkSite {
  id           String        @id @default(uuid())
  name         String
  address      String?
  city         String?
  lat          Float?
  lng          Float?
  type         String        @default("nodo")
  status       String        @default("active")
  deviceCount  Int           @default(0)
  clientCount  Int           @default(0)
  uplink       String?
  parentSiteId String?
  parent       NetworkSite?  @relation("SiteHierarchy", fields: [parentSiteId], references: [id])
  children     NetworkSite[] @relation("SiteHierarchy")
  description  String?
  createdAt    DateTime      @default(now())
}

model NasServer {
  id           String    @id @default(uuid())
  name         String
  type         String
  ipAddress    String
  radiusSecret String?
  nasIpAddress String?
  apiPort      Int?
  apiLogin     String?
  apiPassword  String?
  status       String    @default("active")
  lastSeen     DateTime?
  clientCount  Int       @default(0)
  description  String?
  createdAt    DateTime  @default(now())
}

model RadiusConfig {
  id                    String  @id @default("singleton")
  authPort              Int     @default(1812)
  acctPort              Int     @default(1813)
  coaPort               Int     @default(3799)
  sessionTimeout        Int     @default(86400)
  idleTimeout           Int     @default(3600)
  interimUpdateInterval Int     @default(300)
  nasType               String  @default("other")
  enableCoa             Boolean @default(true)
  enableAccounting      Boolean @default(true)
}

model RadiusSession {
  id            String   @id @default(uuid())
  sessionId     String   @unique
  clientId      String
  clientName    String
  nasId         String?
  nasName       String?
  ipAddress     String?
  macAddress    String?
  startedAt     DateTime @default(now())
  duration      Int      @default(0)
  downloadBytes BigInt   @default(0)
  uploadBytes   BigInt   @default(0)
  downloadMbps  Float    @default(0)
  uploadMbps    Float    @default(0)
  status        String   @default("active")
  username      String?

  @@index([clientId])
}

model CpeDevice {
  id              String    @id @default(uuid())
  serialNumber    String?
  model           String?
  manufacturer    String?
  type            String
  macAddress      String?
  ipAddress       String?
  status          String    @default("unconfigured")
  clientId        String?
  clientName      String?
  nasId           String?
  networkSiteId   String?
  firmwareVersion String?
  lastSeen        DateTime?
  signal          Float?
  connectedAt     DateTime?
  description     String?
  createdAt       DateTime  @default(now())

  @@index([clientId])
}

model OltDevice {
  id           String      @id @default(uuid())
  name         String
  ipAddress    String?
  model        String?
  manufacturer String?
  uplink       String?
  ponPorts     Int         @default(0)
  totalOnus    Int         @default(0)
  onlineOnus   Int         @default(0)
  status       String      @default("online")
  lastSeen     DateTime?
  onus         OnuDevice[]
  createdAt    DateTime    @default(now())
}

model OnuDevice {
  id              String    @id @default(uuid())
  serialNumber    String?
  model           String?
  oltId           String
  olt             OltDevice @relation(fields: [oltId], references: [id])
  ponPort         Int?
  onuId           Int?
  clientId        String?
  clientName      String?
  status          String    @default("unconfigured")
  rxPower         Float?
  txPower         Float?
  distance        Float?
  firmwareVersion String?
  lastSeen        DateTime?
  createdAt       DateTime  @default(now())

  @@index([oltId])
  @@index([clientId])
}

model Tr069Profile {
  id                String        @id @default(uuid())
  name              String
  manufacturerModel String?
  description       String?
  config            Json
  status            String        @default("active")
  devices           Tr069Device[]
}

model Tr069Device {
  id              String        @id @default(uuid())
  deviceId        String
  clientId        String?
  clientName      String?
  profileId       String?
  profile         Tr069Profile? @relation(fields: [profileId], references: [id])
  lastProvisioned DateTime?
  status          String        @default("unconfigured")
  createdAt       DateTime      @default(now())

  @@index([clientId])
}

model HardwareAsset {
  id            String    @id @default(uuid())
  name          String
  type          String
  manufacturer  String?
  model         String?
  serialNumber  String?
  purchaseDate  DateTime?
  purchasePrice Float?
  location      String?
  status        String    @default("in_use")
  warranty      String?
  assignedTo    String?
  notes         String?
  createdAt     DateTime  @default(now())
}

model Ubicacion {
  id          String      @id @default(uuid())
  name        String
  city        String?
  address     String?
  province    String?
  country     String      @default("Argentina")
  lat         Float?
  lng         Float?
  type        String?
  status      String      @default("active")
  managerName String?
  clientCount Int         @default(0)
  timezone    String?
  parentId    String?
  parent      Ubicacion?  @relation("UbicacionHierarchy", fields: [parentId], references: [id])
  children    Ubicacion[] @relation("UbicacionHierarchy")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model DashboardStat {
  id                  String   @id @default("singleton")
  newClientsThisMonth Int      @default(0)
  activeClients       Int      @default(0)
  openTickets         Int      @default(0)
  pendingTickets      Int      @default(0)
  unresponsiveDevices Int      @default(0)
  onlineDevices       Int      @default(0)
  revenueThisMonth    Float    @default(0)
  unpaidInvoices      Int      @default(0)
  overdueInvoices     Int      @default(0)
  cpuUsage            Float    @default(0)
  ramUsage            Float    @default(0)
  diskUsage           Float    @default(0)
  uptime              String   @default("0d 0h")
  updatedAt           DateTime @updatedAt
}

// =============================================
// IPV6 DOMAIN
// =============================================

model Ipv6Network {
  id          String   @id @default(uuid())
  name        String
  network     String
  type        String   @default("global")
  status      String   @default("active")
  description String?
  assignedTo  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// =============================================
// FINANCE SETTINGS
// =============================================

model FinanceSettings {
  id                   String   @id @default("singleton")
  invoiceDueDays       Int      @default(10)
  taxName              String   @default("IVA")
  taxRate              Float    @default(21)
  taxIncluded          Boolean  @default(false)
  autoGenerateInvoices Boolean  @default(true)
  invoiceDay           Int      @default(1)
  lateFeeEnabled       Boolean  @default(false)
  lateFeeAmount        Float    @default(0)
  lateFeeDays          Int      @default(30)
  reminderDays         Json     @default("[7, 3, 1]")
  currency             String   @default("ARS")
  currencySymbol       String   @default("$")
  updatedAt            DateTime @updatedAt
}

// =============================================
// MONITORING DOMAIN
// =============================================

model MonitoringDevice {
  id            String    @id @default(uuid())
  name          String
  ipAddress     String?
  type          String
  status        String    @default("online")
  lastSeen      DateTime?
  uptimePercent Float?
  location      String?
  createdAt     DateTime  @default(now())
}

model MonitoringAlert {
  id             String    @id @default(uuid())
  deviceId       String?
  type           String
  severity       String    @default("warning")
  message        String
  acknowledged   Boolean   @default(false)
  acknowledgedAt DateTime?
  acknowledgedBy String?
  createdAt      DateTime  @default(now())

  @@index([acknowledged])
}
